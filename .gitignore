# Local secrets and environment files
.env
.env.*
!.env.example

# Python local environments and caches
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.cache/
*.cache

# Test and coverage output
.coverage
coverage/
htmlcov/

# Frontend dependencies and generated builds
node_modules/
.next/
dist/
build/

# Runtime logs and process output
logs/
*.log
*.err
*.out
*.tmp
*.bak

# Local text extracts and scratch notes
*.txt
!requirements.txt
!requirements-dev.txt

# Heavy raw API payloads; processed/exported delivery data stays trackable.
data/raw/**/*.jsonl

# Local Codex workspace artifacts
.codex/

# Generated dashboard screenshots are embedded in the final PDF report.
dashboard/screenshots/

# Notebook/editor generated state
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# OS/editor metadata
.DS_Store
Thumbs.db

# Final data exports remain commit-able.
!dashboard/exports/**/*.csv
!dashboard/exports/**/*.json
